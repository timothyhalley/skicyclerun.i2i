{
  "pipeline": {
    "name": "SkiCycleRun Photo Processing Pipeline",
    "version": "1.0.0",
    "stages": [
      "export",
      "cleanup",
      "metadata_extraction",
      "preprocessing",
      "lora_processing",
      "post_lora_watermarking",
      "s3_deployment"
    ]
  },
  "paths": {
    "apple_photos_export": "/Volumes/MySSD/ImageLib/phase1_extract/raw",
    "raw_input": "/Volumes/MySSD/ImageLib/phase1_extract/raw",
    "preprocessed": "/Volumes/MySSD/ImageLib/phase1_extract/scaled",
    "watermarked": "/Volumes/MySSD/ImageLib/phase1_extract/watermarked",
    "output": "/Volumes/MySSD/ImageLib/phase1_extract/ready_for_lora",
    "archive": "/Volumes/MySSD/ImageLib/archive",
    "metadata_catalog": "/Volumes/MySSD/ImageLib/phase1_extract/metadata/catalog.json"
  },
  "export": {
    "enabled": true,
    "source": "apple_photos",
    "format": "jpeg",
    "quality": 95,
    "preserve_albums": true,
    "script_path": "scripts/osxPhotoExporter.scpt"
  },
  "cleanup": {
    "enabled": true,
    "archive_old_outputs": true,
    "remove_temp_files": true,
    "archive_retention_days": 30
  },
  "metadata_extraction": {
    "enabled": true,
    "extract_exif": true,
    "extract_geolocation": true,
    "geocoding": {
      "provider": "nominatim",
      "api_url": "https://nominatim.openstreetmap.org/reverse",
      "user_agent": "SkiCycleRun/1.0",
      "rate_limit_seconds": 1.0,
      "cache_enabled": true,
      "cache_file": "/Volumes/MySSD/ImageLib/metadata/geocode_cache.json"
    }
  },
  "preprocessing": {
    "enabled": true,
    "max_dimension": 2048,
    "format": "webp",
    "quality": 90,
    "preserve_aspect_ratio": true,
    "optimize": true,
    "catalog_metadata": true
  },
  "watermark": {
    "enabled": false,
    "format": "SkiCycleRun © {year} {astro_symbol} {location}",
    "year_offset": 1,
    "font": {
      "family": "Asimovian",
      "size": 24,
      "color": [255, 255, 255, 180],
      "stroke_color": [0, 0, 0, 200],
      "stroke_width": 2
    },
    "position": "bottom_right",
    "margin": { "x": 20, "y": 20 },
    "apply_before_lora": false
  },
  "lora_processing": {
    "enabled": true,
    "use_existing_config": true,
    "config_path": "config/default_config.json",
    "registry_path": "config/lora_registry.json",
    "batch_mode": true,
    "preserve_metadata": true,
    "loras_to_process": [
      "Afremov",
      "Gorillaz",
      "Origami",
      "PencilDrawing",
      "FractalGeometry",
      "Poly_Futurism"
    ],
    "input_folder": "/Volumes/MySSD/ImageLib/phase1_extract/scaled",
    "output_folder": "/Volumes/MySSD/ImageLib/phase2_lora/processed"
  },
  "s3_deployment": {
    "enabled": true,
    "bucket_name": "skicyclerun.lib",
    "bucket_prefix": "albums",
    "source_folder": "/Volumes/MySSD/ImageLib/phase2_lora/watermarked",
    "aws_profile": "default",
    "preserve_album_structure": true,
    "content_type": "image/webp",
    "cache_control": "max-age=31536000, public",
    "storage_class": "STANDARD",
    "dry_run": false
  },
  "logging": {
    "level": "INFO",
    "console": true,
    "file": "logs/pipeline_{timestamp}.log",
    "include_timestamps": true
  }
}

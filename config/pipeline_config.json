{
  "pipeline": {
    "name": "SkiCycleRun Photo Processing Pipeline",
    "version": "1.0.0",
    "stages": [
      "export",
      "cleanup",
      "metadata_extraction",
      "preprocessing",
      "lora_processing",
      "post_lora_watermarking",
      "s3_deployment"
    ]
  },
  "paths": {
    "lib_root": "${SKICYCLERUN_LIB_ROOT:/Volumes/MySSD/skicyclerun.i2i}",
    "huggingface_cache": "${HUGGINGFACE_CACHE_LIB:/Volumes/MySSD/huggingface}",
    "lora_models": "{lib_root}/models/lora",
    "pipeline_base": "{lib_root}/pipeline",
    "archive_albums": "{pipeline_base}/archive/albums",
    "archive_metadata": "{pipeline_base}/archive/metadata",
    "apple_photos_export": "{pipeline_base}/albums",
    "raw_input": "{pipeline_base}/albums",
    "metadata_dir": "{pipeline_base}/metadata",
    "preprocessed": "{pipeline_base}/scaled",
    "lora_processed": "{pipeline_base}/lora_processed",
    "watermarked_final": "{pipeline_base}/watermarked_final",
    "pre_lora_watermarked": "{pipeline_base}/watermarked_final",
    "final_albums": "{pipeline_base}/watermarked_final",
    "archive": "{pipeline_base}/archive",
    "master_catalog": "{metadata_dir}/master.json"
  },
  "export": {
    "enabled": true,
    "source": "apple_photos",
    "format": "jpeg",
    "quality": 95,
    "preserve_albums": true,
    "script_path": "scripts/osxPhotoExporter.scpt"
  },
  "cleanup": {
    "enabled": true,
    "archive_old_outputs": true,
    "remove_temp_files": true,
    "archive_retention_days": 30
  },
  "metadata_extraction": {
    "enabled": true,
    "extract_exif": true,
    "extract_geolocation": true,
    "providers": {
      "geocoding": {
        "active_provider": "nominatim",
        "provider_order": ["nominatim", "photon"],
        "allow_fallback": true,
        "user_agent": "SkiCycleRun/1.0",
        "request_delay_seconds": 1.0,
        "cache": {
          "enabled": true,
          "file": "{metadata_dir}/geocode_cache.json",
          "cache_only": false
        },
        "providers": {
          "nominatim": {
            "api_url": "https://nominatim.openstreetmap.org/reverse",
            "zoom": 16
          },
          "photon": {
            "enabled": true
          },
          "google_maps": {
            "enabled": false,
            "_comment": "Paid provider. Keep disabled unless explicitly needed. API keys must be in .env/env vars only (never JSON).",
            "api_key_env_var": "GOOGLE_MAPS_API_KEY",
            "geocode_api_url": "https://maps.googleapis.com/maps/api/geocode/json",
            "places_api_url": "https://maps.googleapis.com/maps/api/place/nearbysearch/json",
            "max_calls_per_run": 0
          }
        }
      },
      "poi": {
        "enabled": true,
        "active_provider": "overpass",
        "single_call_per_photo": true,
        "dedupe_per_coordinate_per_run": true,
        "search": {
          "radius_m": 50,
          "progressive_radii_m": [50, 120, 250],
          "max_results": 5,
          "categories": [
            "lodging",
            "restaurant",
            "cafe",
            "marketplace",
            "park",
            "trailhead",
            "beach",
            "mountain",
            "peak",
            "volcano",
            "waterfall",
            "historic",
            "memorial",
            "monument",
            "museum",
            "gallery",
            "attraction",
            "viewpoint",
            "national_park",
            "protected_area"
          ],
          "use_heading_filter": false,
          "fov_degrees": 60,
          "max_distance_m": 0,
          "heading_weight": 0.7,
          "distance_weight": 0.3
        },
        "providers": {
          "overpass": {
            "timeout_seconds": 10,
            "request_delay_seconds": 0.25,
            "rate_limit_backoff_seconds": 60
          }
        }
      }
    }
  },
  "preprocessing": {
    "enabled": true,
    "max_dimension": 2048,
    "format": "webp",
    "quality": 90,
    "preserve_aspect_ratio": true,
    "optimize": true,
    "catalog_metadata": true
  },
  "watermark": {
    "enabled": true,
    "bilingual_output": true,
    "layout": "two_line",
    "_comment_line1": "LINE 1 uses the explicit rule {context anchor}{separator}{experience anchor}, built from cached hints/roads/landmarks plus a nearby human-facing POI.",
    "_comment_line2": "LINE 2 is programmatic location text plus copyright branding.",
    "line1_style": "clean",
    "line1_rule": {
      "_comment": "Configurable LINE 1 template: {context}{separator}{experience}",
      "separator": " | ",
      "context_types": [
        "street",
        "monument",
        "park",
        "trailhead",
        "beach",
        "peak",
        "waterfall",
        "memorial",
        "attraction",
        "forest",
        "national_park"
      ],
      "experience_types_priority": [
        "restaurant",
        "cafe",
        "hotel",
        "view",
        "monument",
        "memorial",
        "attraction"
      ]
    },
    "llm_blend": {
      "_comment": "Hybrid composition: use LLM phrasing only when grounded by factual metadata/POIs",
      "enabled": true,
      "line1_prefer_llm": true,
      "line1_require_grounding": true,
      "line1_max_words": 10,
      "line2_use_llm_context_prefix": false,
      "line2_require_grounding": true
    },
    "poi_filter": {
      "_comment": "Nearby POI filtering for readable watermark context before LINE 1 composition",
      "max_distance_m": 75,
      "limit": 3,
      "allowed_categories": [
        "restaurant",
        "cafe",
        "bar",
        "hotel",
        "view",
        "landmark",
        "museum",
        "shop"
      ],
      "category_priority": {
        "restaurant": 0,
        "cafe": 1,
        "bar": 2,
        "hotel": 3,
        "view": 4,
        "landmark": 5,
        "museum": 6,
        "shop": 7
      }
    },
    "line1_max_words": 10,
    "line1_poi_max_distance_m": 120,
    "line1_style_options": ["clean", "scenic", "minimal"],
    "location_line": {
      "_comment": "Settings for LINE 1 (programmatic watermark: landmark + city/region + state/country + copyright)",
      "font_size": 28,
      "min_size": 20,
      "color": [255, 255, 255, 220],
      "stroke_color": [0, 0, 0, 255],
      "stroke_width": 3
    },
    "copyright_line": {
      "_comment": "Settings for LINE 2 (location + copyright)",
      "format": "{symbol} SkiCycleRun \u00a9 {year}",
      "font_size": 16,
      "min_size": 12,
      "color": [255, 255, 255, 180],
      "stroke_color": [0, 0, 0, 200],
      "stroke_width": 2
    },
    "line_spacing": 8,
    "symbol": "\u25b2",
    "fixed_year": 2026,
    "year_offset": 1,
    "include_landmark": false,
    "landmark_min_score": 0.6,
    "landmark_max_distance_m": 300,
    "landmark_format": " \u2014 {name}",
    "font": {
      "path": "/System/Library/Fonts/Supplemental/Arial Unicode.ttf",
      "fallback_paths": [
        "fonts/asimovian/Asimovian-Regular.ttf",
        "/System/Library/Fonts/Supplemental/Arial.ttf",
        "/System/Library/Fonts/Helvetica.ttc"
      ],
      "max_width_percent": 80,
      "fit_mode": "shrink_to_fit"
    },
    "position": "bottom_right",
    "margin": {
      "x": 50,
      "y": 40
    },
    "apply_before_lora": false
  },
  "lora_processing": {
    "enabled": true,
    "use_existing_config": true,
    "registry_path": "config/lora_registry.json",
    "batch_mode": true,
    "preserve_metadata": true,
    "_loras_to_process_comment": "Special entries: 'NoLoRA' copies scaled images without style transfer (pass-through mode). Include as first entry to generate unmodified baseline images alongside stylized versions.",
    "loras_to_process": ["Afremov", "Gorillaz"],
    "_Available_loras": [
      "PencilDrawing",
      "FractalGeometry",
      "Afremov",
      "Gorillaz",
      "Origami",
      "NoLoRA"
    ],
    "input_folder": "{preprocessed}",
    "output_folder": "{lora_processed}",
    "input_image": "{preprocessed}/sample.webp",
    "output_format": "webp",
    "max_dim": 1024,
    "num_inference_steps": 24,
    "guidance_scale": 3.5,
    "device": "mps",
    "precision": "bfloat16",
    "preprocess": {
      "enabled": true,
      "cleanup": true,
      "face_detection": false
    },
    "cache_dir": "{huggingface_cache}",
    "local_files_only": false,
    "prompt": "",
    "negative_prompt": ""
  },
  "llm_image_analysis": {
    "enabled": true,
    "model": "gemma4:latest",
    "endpoint": "http://localhost:11434",
    "timeout_seconds": 45,
    "line1_max_words": 8,
    "line2_max_words": 14,
    "_comment": "Optional stage. Generates LLM_Watermark_Line1 and LLM_Watermark_Line2 for each geocode_cache entry."
  },
  "travel_log_generation": {
    "rag_output_name": "{album}-LLMRAG-data.json"
  },
  "travel_story_generation": {
    "enabled": true,
    "prompt_template": "config/travel_story_prompt_template.md",
    "output_name": "{album}-Adventum-{model}.md",
    "prepend_album_title": false,
    "save_resolved_prompt": true,
    "resolved_prompt_name": "{album}-Adventum-prompt.md",
    "prompt_max_chars": 64000,
    "prompt_max_entries": 160,
    "prompt_min_entries": 24,
    "prompt_max_photos_per_entry": 5,
    "prompt_max_pois_per_entry": 3,
    "timeout_seconds": 180,
    "temperature": 0.85,
    "top_p": 0.95,
    "max_tokens": 2600,
    "persona": "Award-winning travel essayist with a cinematic, sensory writing voice",
    "style_guide": "Write with lyrical momentum, precise imagery, and emotional texture while staying fact-grounded. Favor memorable phrasing over bland summary.",
    "format_guide": "Output valid Markdown with one compelling title, a vivid opening, sectioned narrative progression by place/time, emoji-led vignettes, highlights, and a resonant closing reflection.",
    "positive_guidance": [
      "Prioritize factual grounding from the provided RAG metadata",
      "Use a coherent timeline and connect moments into a story arc",
      "Blend place, activity, atmosphere, and contrast in evocative prose",
      "Use specific sensory details rooted in locations and POIs",
      "Craft section headings that feel editorial and destination-specific",
      "Use tasteful emojis for section headers and highlight bullets"
    ],
    "negative_guidance": [
      "Do not invent facts, locations, dates, or events",
      "Avoid generic fluff, filler adjectives, and repetitive wording",
      "Do not contradict RAG metadata",
      "Avoid first-person claims unless explicitly present in metadata",
      "Do not output JSON or code blocks",
      "Do not write like a dry itinerary or technical report"
    ]
  },
  "travel_map_generation": {
    "enabled": true,
    "prompt_template": "config/travel_map_prompt_template.md",
    "target_model": "midjourney",
    "resolve_with_local_llm": true,
    "strict_sync": false,
    "save_request_prompt": true,
    "request_output_name": "{album}-navigium-request.md",
    "prompt_output_name": "{album}-navigium-prompt.md",
    "label_policy": "cities_and_pois",
    "image_width": 800,
    "image_height": 800,
    "timeout_seconds": 180,
    "temperature": 0.30,
    "top_p": 0.90,
    "max_tokens": 2600,
    "artist_style": "Guillaume Kurkdjian",
    "artist_style_list": "Ângelo Fernandes, To Binh Binh, Nguyen Thanh, Guillaume Kurkdjian",
    "artist_style_briefs": {
      "Guillaume Kurkdjian": "Clean isometric perspective, warm sunlit color palette, soft gradients, playful geometric precision, miniature icon treatment for POIs, crisp linework, balanced composition with foreground to midground to background depth.",
      "Ângelo Fernandes": "Vibrant flat illustration, bold color blocks, geometric stylization, graphic poster aesthetic, strong silhouettes, minimal shading.",
      "To Binh Binh": "Delicate ink linework, layered texture, earthy tones, fine hatching detail, architectural intimacy, hand-drawn feel.",
      "Nguyen Thanh": "Painterly digital rendering, rich atmospheric light, loose gestural strokes, luminous color harmony, impressionistic depth."
    }
  },
  "s3_deployment": {
    "enabled": true,
    "bucket_name": "skicyclerun.lib",
    "bucket_prefix": "albums",
    "source_folder": "{watermarked_final}",
    "aws_profile": "default",
    "preserve_album_structure": true,
    "content_type": "image/webp",
    "cache_control": "max-age=31536000, public",
    "storage_class": "STANDARD",
    "dry_run": false,
    "cloudfront": {
      "enabled": true,
      "distribution_id": "E1GQ61X0LT69AR",
      "paths": [],
      "wait_for_completion": false
    }
  },
  "logging": {
    "level": "INFO",
    "console": true,
    "file": "{pipeline_base}/logs/pipeline_{timestamp}.log",
    "include_timestamps": true
  },
  "python_environment": {
    "python_version": "3.13.12",
    "profile": "performance/MINI_ProfileOG.txt",
    "lib_root": "/Volumes/MySSD/skicyclerun.i2i",
    "huggingface_cache": "/Volumes/MySSD/huggingface",
    "last_setup": "2026-04-02T20:34:40Z"
  }
}
